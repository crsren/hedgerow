{
  "name": "hedgerow-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "verify:packaging": "TURBO_TELEMETRY_DISABLED=1 turbo run build --filter=./packages/* && node scripts/verify-packaging.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm verify:packaging && pnpm api:check && node scripts/check-changesets.mjs && changeset publish",
    "api:report": "turbo run build --filter=./packages/* && node scripts/api-report.mjs",
    "api:check": "turbo run build --filter=./packages/* && node scripts/api-report.mjs --check",
    "release:ci": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "publint": "^0.3.21",
    "turbo": "^2.3.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
