---
import MarkdownIt from "markdown-it";
import Base from "../layouts/Base.astro";
import { loadSite, slugOf } from "../lib/site";
import CommentThread from "../components/CommentThread";
import type { DocumentRecord } from "@hedgerow/publish";
import { fetchLikes, fetchThread, type LikesResult, type ThreadResult } from "@hedgerow/comments";

// html: false (the default) is the sanitization here: raw HTML in the
// markdown source is escaped as text rather than passed through, so an
// edited-via-Tiptap (or hand-authored) post can't smuggle a <script>/<style>
// tag into the rendered page. The content is author-owned (their own signed
// PDS record), but there's no reason to trust it more than that.
const md = new MarkdownIt({ linkify: true });

// SSR thread snapshot (SLIMS-69): fetch the comment thread + likes on the
// server (this package is Node-safe — no DOM/browser assumptions) so the
// first HTML response already has the comments in it, closing the
// comments-loading-gap the client-hydrated island otherwise leaves. This is
// polish, not a hard dependency: a failure here just means the page falls
// back to exactly the old behavior (the island fetches client-side on
// mount) — see the try/catch below. Inlined into getStaticPaths (rather than
// a separate top-level helper) because Astro's static-build bundler tree-shook
// a standalone async function here out of the getStaticPaths chunk even
// though it was called — a real, reproduced build failure
// ("fetchInitialComments is not defined" at build time despite a clean
// `astro check`/`tsc --noEmit`), not a hypothetical.
export async function getStaticPaths() {
  const { documents } = await loadSite();
  // Same override HEDGEROW_APPVIEW_URL loadSite() itself doesn't need (it
  // reads records straight from the PDS/PLC), but the comments read core
  // always goes through an AppView — see docs/local-testing.md.
  const appView = process.env.HEDGEROW_APPVIEW_URL;
  const appViewOpts = appView ? { appView } : {};

  return Promise.all(
    documents.map(async ({ uri, value, bskyPostUri }) => {
      let initialThread: ThreadResult | undefined;
      let initialLikes: LikesResult | undefined;
      if (bskyPostUri) {
        try {
          [initialThread, initialLikes] = await Promise.all([
            fetchThread(bskyPostUri, { maxDepth: 6, ...appViewOpts }),
            fetchLikes(bskyPostUri, appViewOpts),
          ]);
        } catch {
          // AppView hiccup, post not yet indexed, etc. — the island's own
          // client-side fetch (unconditionally still wired below) is the
          // fallback, exactly the pre-SSR-snapshot behavior.
        }
      }
      return {
        params: { slug: slugOf(value) },
        props: {
          doc: value,
          recordUri: uri,
          bskyPostUri: bskyPostUri ?? null,
          initialThread,
          initialLikes,
        },
      };
    }),
  );
}

interface Props {
  doc: DocumentRecord;
  recordUri: string | null;
  bskyPostUri: string | null;
  initialThread?: ThreadResult;
  initialLikes?: LikesResult;
}
const { doc, recordUri, bskyPostUri, initialThread, initialLikes } = Astro.props;

// SLIMS-64: prefer the rich `content` union's markdown member, rendered to
// HTML server-side, when present — falling back to textContent's plaintext
// paragraphs (exactly as before) for documents that only carry the plain
// mirror (older records, or a loose standard.site document from elsewhere).
const bodyHtml = doc.content?.markdown ? md.render(doc.content.markdown) : null;

// textContent is plaintext; the only structure it carries is paragraph breaks
// (double newlines). Split those back into <p> elements — single newlines within
// a paragraph collapse to spaces in HTML, which is exactly the hard-wrapped source.
const paragraphs = (doc.textContent ?? "")
  .split(/\n{2,}/)
  .map((p) => p.trim())
  .filter(Boolean);

const dateFmt = new Intl.DateTimeFormat("en", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base title={doc.title} description={doc.description} recordUri={recordUri}>
  <p class="back"><a href="/">← All posts</a></p>

  <article>
    <h1>{doc.title}</h1>
    <time datetime={doc.publishedAt}>
      {dateFmt.format(new Date(doc.publishedAt))}
    </time>

    {
      doc.tags && doc.tags.length > 0 && (
        <ul class="tags">
          {doc.tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )
    }

    <div class="body">
      {bodyHtml ? <Fragment set:html={bodyHtml} /> : paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </article>

  {
    bskyPostUri && (
      <section class="comments" aria-labelledby="comments-heading">
        <h2 id="comments-heading">Comments</h2>
        {/* Client-hydrated island. The article above is 100% static HTML;
            initialThread/initialLikes (fetched server-side above) render the
            comments straight into this page's HTML too — verify with
            `curl`, no browser needed — and the island revalidates once it
            hydrates (client:visible), same as before this existed. */}
        <CommentThread
          client:visible
          post={bskyPostUri}
          initialThread={initialThread}
          initialLikes={initialLikes}
        />
      </section>
    )
  }

  <footer>
    <p class="muted">Rendered from a site.standard.document record</p>
  </footer>
</Base>

<style>
  .back {
    margin: 0 0 2.5rem;
    font-size: 0.9rem;
  }

  time {
    display: block;
    margin-bottom: 1rem;
  }

  .tags {
    margin-bottom: 2.5rem;
  }

  .body {
    font-size: 1.08rem;
  }
  .body p {
    margin: 0 0 1.4rem;
  }

  .comments {
    margin-top: 1rem;
  }
  .comments h2 {
    font-size: 1.1rem;
    letter-spacing: -0.01em;
    margin: 0;
  }

  footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  footer .muted {
    font-size: 0.85rem;
    margin: 0;
  }
</style>
