{
  "name": "@hedgerow/comments",
  "version": "0.1.0",
  "description": "Framework-agnostic read core for Bluesky comments and likes: resolve a post, page its replies and likes off the public AppView, shape them into a tree.",
  "keywords": [
    "atproto",
    "at-protocol",
    "bluesky",
    "comments",
    "likes",
    "isomorphic"
  ],
  "homepage": "https://github.com/crsren/hedgerow/tree/main/packages/comments",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crsren/hedgerow.git",
    "directory": "packages/comments"
  },
  "bugs": "https://github.com/crsren/hedgerow/issues",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "prepublishOnly": "node ../../scripts/assert-publish-context.mjs && node ../../scripts/assert-dist-tag.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "capture-fixtures": "node scripts/capture-fixtures.mjs",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@hedgerow/tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.3.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
