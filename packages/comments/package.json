{
  "name": "@hedgerow/comments",
  "version": "0.0.1",
  "description": "Framework-agnostic read core for Bluesky comments and likes: resolve a post, page its replies and likes off the public AppView, shape them into a tree.",
  "keywords": ["atproto", "at-protocol", "bluesky", "comments", "likes", "isomorphic"],
  "homepage": "https://github.com/crsren/hedgerow/tree/main/packages/comments",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "capture-fixtures": "node scripts/capture-fixtures.mjs"
  },
  "devDependencies": {
    "@hedgerow/tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
