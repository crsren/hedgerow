{
  "name": "@hedgerow/publish",
  "version": "0.1.0",
  "description": "Publish markdown posts as standard.site atproto records to a PDS.",
  "keywords": [
    "atproto",
    "at-protocol",
    "standard.site",
    "indieweb",
    "publishing"
  ],
  "homepage": "https://github.com/crsren/hedgerow/tree/main/packages/publish",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crsren/hedgerow.git",
    "directory": "packages/publish"
  },
  "bugs": "https://github.com/crsren/hedgerow/issues",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "development": "./src/node.ts",
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "lexicons",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./node": {
        "types": "./dist/node.d.ts",
        "import": "./dist/node.js",
        "default": "./dist/node.js"
      }
    }
  },
  "scripts": {
    "prepublishOnly": "node ../../scripts/assert-publish-context.mjs && node ../../scripts/assert-dist-tag.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@atproto/api": "^0.20.0",
    "@atproto/common-web": "^0.4.0",
    "@atproto/oauth-client-node": "^0.4.9",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@atproto/dev-env": "^0.5.35",
    "@atproto/lexicon": "^0.7.7",
    "@hedgerow/tsconfig": "workspace:*",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.3.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
