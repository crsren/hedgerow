{
  "name": "@hedgerow/react",
  "version": "0.0.1",
  "description": "Headless, unstyled React components and hooks for rendering Bluesky comments and likes on your own site. Behaviour, accessibility, and state only \u2014 you bring the styles.",
  "keywords": [
    "atproto",
    "at-protocol",
    "bluesky",
    "comments",
    "likes",
    "react",
    "headless",
    "unstyled"
  ],
  "homepage": "https://github.com/crsren/hedgerow/tree/main/packages/react",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crsren/hedgerow.git",
    "directory": "packages/react"
  },
  "bugs": "https://github.com/crsren/hedgerow/issues",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hedgerow/comments": "workspace:*"
  },
  "devDependencies": {
    "@hedgerow/tsconfig": "workspace:*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  }
}
