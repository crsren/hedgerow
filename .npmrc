# Install peer dependencies automatically.
#
# The comment that used to sit here claimed this "keeps the store strict so a
# package can only import what it declares" — the opposite of what the setting
# does. Strictness against phantom dependencies comes from `files` +
# publishConfig.exports and is verified by scripts/verify-packaging.mjs, which
# packs each tarball and performs a real import() against it.
#
# Known consequence, deliberately accepted: this can satisfy a peer (notably
# react) from somewhere other than an explicit override, which is why the
# react-compat CI job asserts the RESOLVED react major before running the
# suite — otherwise a "React 19" leg could silently run React 18.
auto-install-peers=true
